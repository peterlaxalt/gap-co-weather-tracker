# Get a free key at https://openweathermap.org/api  ->  "Current Weather Data" / "5 day 3 hour forecast"
# (Free tier, no credit card required. New keys can take ~1-2 hours to activate.)
OPENWEATHER_API_KEY=your_key_here

# Optional: the calendar date your trip starts (YYYY-MM-DD), used to label forecast
# days as "Day 1", "Day 2", etc. Leave unset to just label by calendar date.
TRIP_START_DATE=
